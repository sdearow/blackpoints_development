dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Ambienti virtuali ---
.venv/
venv/
env/
ENV/

# --- Test e coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# --- Notebook ---
.ipynb_checkpoints/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Dati (non versionati) ---
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
# I CSV degli incidenti grezzi sono versionati esplicitamente.
!data/raw/incidenti/
!data/raw/incidenti/*.csv
# GeoJSON dei risultati finali: versionata la sola copia compressa
# (il file piano dei segmenti supera i 50 MB -> warning GitHub a ogni
# push). geopandas/QGIS leggono i .geojson.gz direttamente.
!data/processed/segmenti.geojson.gz
!data/processed/intersezioni.geojson.gz

# --- Output dashboard / report ---
dashboard/assets/generated/
reports/generated/

# --- File di output geospaziali e tabellari grandi ---
*.gpkg
*.parquet
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.qix

# --- Censimento ISTAT (input del modulo Equita', versionato esplicitamente) ---
!data/raw/censimento/
!data/raw/censimento/*.gpkg
!data/raw/censimento/*.xlsx

# --- Database progetti/interventi (input del modulo Equita') ---
!data/raw/progetti/
!data/raw/progetti/*.gpkg
!data/raw/progetti/*.qgz
!data/raw/progetti/*.csv
